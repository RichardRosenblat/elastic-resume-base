# ── AI Worker — local development environment template ──────────────────────
# Copy to .env and fill in values.  config.yaml takes precedence for shared
# settings; .env provides local overrides for service-specific values.
# Never commit .env — it is git-ignored.

# Required
PROJECT_ID=demo-elastic-resume-base

# Pub/Sub
PUBSUB_PROJECT_ID=demo-elastic-resume-base
PUBSUB_OUTPUT_TOPIC=resume_indexing
PUBSUB_DLQ_TOPIC=dead-letter-queue
PUBSUB_EMULATOR_HOST=localhost:8085

# Firestore (via Synapse)
FIRESTORE_RESUMES_COLLECTION=resumes
FIRESTORE_EMBEDDINGS_COLLECTION=resume_embeddings
FIRESTORE_EMULATOR_HOST=localhost:8080

# Vertex AI (only allowed direct GCP dep)
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_EXTRACTION_MODEL=gemini-1.5-flash
VERTEX_AI_EMBEDDING_MODEL=text-multilingual-embedding-002
VERTEX_AI_MAX_CALLS_PER_MINUTE=60

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# DLQ alerts (via Hermes SMTP)
DLQ_ALERT_RECIPIENT=ops@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@ai-worker.local

# Logging
LOG_LEVEL=INFO
