# AI Worker Service — environment variables
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to source control.

# GCP project identifier (required)
PROJECT_ID=demo-project

# Firestore collection for resumes (default: resumes)
FIRESTORE_RESUMES_COLLECTION=resumes

# Pub/Sub topics
PUBSUB_INPUT_TOPIC=resume-ingested
PUBSUB_OUTPUT_TOPIC=resume-indexed
PUBSUB_DLQ_TOPIC=dead-letter-queue

# Vertex AI configuration
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_EXTRACTION_MODEL=gemini-1.5-flash
VERTEX_AI_EMBEDDING_MODEL=text-multilingual-embedding-002

# DLQ alert recipient (Hermes)
DLQ_ALERT_RECIPIENT=ops@example.com

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# SMTP settings for Hermes (DLQ alerts)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@example.com
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
