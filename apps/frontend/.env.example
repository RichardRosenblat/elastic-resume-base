VITE_GATEWAY_URL=http://localhost:3000

# Support contact email shown in the footer of every page.
# Leave empty to hide the footer entirely.
VITE_SUPPORT_EMAIL=

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# Shared in config.yaml as FIREBASE_PROJECT_ID; Vite derives VITE_FIREBASE_PROJECT_ID automatically.
FIREBASE_PROJECT_ID=demo-elastic-resume-base

VITE_FEATURE_RESUME_INGEST=false
VITE_FEATURE_RESUME_SEARCH=false
VITE_FEATURE_DOCUMENT_READ=false
VITE_FEATURE_RESUME_GENERATE=false
VITE_FEATURE_USER_MANAGEMENT=true

# Branding, colours, fonts, and dark/light mode are configured in
# src/theme/theme.json — not through environment variables.
