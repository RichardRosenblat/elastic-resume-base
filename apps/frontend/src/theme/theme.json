{
  "mode": "light",
  "variables": {
    "white": "#FFFFFF",
    "primaryMain": "#1F5AA6",
    "primaryLight": "#4B84CE",
    "primaryDark": "#163F73",
    "secondaryMain": "#0D9488",
    "secondaryLight": "#3AB9AD",
    "secondaryDark": "#0A6C63",
    "tertiaryMain": "#F59E0B",
    "successMain": "#198754",
    "warningMain": "#B7791F",
    "errorMain": "#C53030",
    "infoMain": "#2563EB",
    "bgDefault": "#F3F7FC",
    "bgSidebar": "#EAF1FB",
    "textPrimary": "#112133",
    "textSecondary": "#3E5166",
    "textMuted": "#657990",
    "uiBorder": "#CFDAE8",
    "uiDivider": "#D8E2EE",
    "uiDisabledBg": "#E6ECF4",
    "uiDisabledText": "#8092A6",
    "uiFocusRing": "#3A7BD5",
    "alertSuccessBg": "#EDF7ED",
    "alertSuccessColor": "#1D5E28",
    "alertWarningBg": "#FFF8E1",
    "alertWarningColor": "#7A5310",
    "alertErrorBg": "#FDEDED",
    "alertErrorColor": "#8B1A1A",
    "alertInfoBg": "#E8F4FD",
    "alertInfoColor": "#1A4B8C",
    "darkPrimaryLight": "#79ABDF",
    "darkSecondaryLight": "#68CFC5",
    "darkSuccessMain": "#4ADE80",
    "darkWarningMain": "#FBBF24",
    "darkErrorMain": "#F87171",
    "darkInfoMain": "#60A5FA",
    "darkBgDefault": "#0F172A",
    "darkBgPaper": "#1E293B",
    "darkBgElevated": "#263449",
    "darkBgSidebar": "#162032",
    "darkBgTopbar": "#1A2840",
    "darkTextPrimary": "#F1F5F9",
    "darkTextSecondary": "#94A3B8",
    "darkTextMuted": "#64748B",
    "darkUiBorder": "#2D3F56",
    "darkUiDivider": "#233045",
    "darkUiDisabledBg": "#1E2D3D",
    "darkUiDisabledText": "#506275",
    "darkAlertSuccessBg": "#0D2B17",
    "darkAlertSuccessColor": "#86EFAC",
    "darkAlertSuccessFilledBg": "#15803D",
    "darkAlertWarningBg": "#2B1D0A",
    "darkAlertWarningColor": "#FCD34D",
    "darkAlertWarningFilledBg": "#B45309",
    "darkAlertErrorBg": "#2B0D0D",
    "darkAlertErrorColor": "#FCA5A5",
    "darkAlertErrorFilledBg": "#DC2626",
    "darkAlertInfoBg": "#0D1F3C",
    "darkAlertInfoColor": "#93C5FD",
    "darkAlertInfoFilledBg": "#1D4ED8",
    "darkAlertDefaultFilledBg": "#334155"
  },
  "branding": {
    "appName": "Elastic Resume Base",
    "companyName": "Acme Talent",
    "appLogoUrl": "",
    "companyLogoUrl": ""
  },
  "typography": {
    "fontFamily": "\"Source Sans 3\", \"Segoe UI\", \"Helvetica Neue\", sans-serif"
  },
  "icons": {
    "default": "mdi:home"
  },
  "palette": {
    "primary": {
      "main": "$primaryMain",
      "light": "$primaryLight",
      "dark": "$primaryDark",
      "contrastText": "$white"
    },
    "secondary": {
      "main": "$secondaryMain",
      "light": "$secondaryLight",
      "dark": "$secondaryDark",
      "contrastText": "$white"
    },
    "tertiary": {
      "main": "$tertiaryMain"
    },
    "success": { "main": "$successMain" },
    "warning": { "main": "$warningMain" },
    "error": { "main": "$errorMain" },
    "info": { "main": "$infoMain" },
    "background": {
      "default": "$bgDefault",
      "paper": "$white",
      "elevated": "$white",
      "sidebar": "$bgSidebar",
      "topbar": "$white",
      "input": "$white"
    },
    "text": {
      "primary": "$textPrimary",
      "secondary": "$textSecondary",
      "muted": "$textMuted",
      "inverse": "$white"
    },
    "ui": {
      "border": "$uiBorder",
      "divider": "$uiDivider",
      "disabledBackground": "$uiDisabledBg",
      "disabledText": "$uiDisabledText",
      "focusRing": "$uiFocusRing"
    },
    "alerts": {
      "success": {
        "bg": "$alertSuccessBg",
        "color": "$alertSuccessColor",
        "filledBg": "$successMain",
        "filledColor": "$white"
      },
      "warning": {
        "bg": "$alertWarningBg",
        "color": "$alertWarningColor",
        "filledBg": "$warningMain",
        "filledColor": "$white"
      },
      "error": {
        "bg": "$alertErrorBg",
        "color": "$alertErrorColor",
        "filledBg": "$errorMain",
        "filledColor": "$white"
      },
      "info": {
        "bg": "$alertInfoBg",
        "color": "$alertInfoColor",
        "filledBg": "$infoMain",
        "filledColor": "$white"
      },
      "default": {
        "bg": "$bgDefault",
        "color": "$textSecondary",
        "filledBg": "$textSecondary",
        "filledColor": "$white"
      }
    }
  },
  "sidebar": {
    "mainScreen": "/",
    "defaultCollapsed": false,
    "items": [
      { "path": "/", "order": 1 },
      { "path": "/resumes", "order": 2 },
      { "path": "/search", "order": 3 },
      { "path": "/documents", "order": 4 },
      { "path": "/users", "order": 5 },
      { "path": "/system-status", "order": 6 },
      { "path": "/account", "order": 7 }
    ]
  },
  "presets": {
    "dark": {
      "primary": {
        "main": "$primaryLight",
        "light": "$darkPrimaryLight",
        "dark": "$primaryMain",
        "contrastText": "$white"
      },
      "secondary": {
        "main": "$secondaryLight",
        "light": "$darkSecondaryLight",
        "dark": "$secondaryMain",
        "contrastText": "$white"
      },
      "tertiary": {
        "main": "$tertiaryMain"
      },
      "success": { "main": "$darkSuccessMain" },
      "warning": { "main": "$darkWarningMain" },
      "error": { "main": "$darkErrorMain" },
      "info": { "main": "$darkInfoMain" },
      "background": {
        "default": "$darkBgDefault",
        "paper": "$darkBgPaper",
        "elevated": "$darkBgElevated",
        "sidebar": "$darkBgSidebar",
        "topbar": "$darkBgTopbar",
        "input": "$darkBgElevated"
      },
      "text": {
        "primary": "$darkTextPrimary",
        "secondary": "$darkTextSecondary",
        "muted": "$darkTextMuted",
        "inverse": "$darkBgDefault"
      },
      "ui": {
        "border": "$darkUiBorder",
        "divider": "$darkUiDivider",
        "disabledBackground": "$darkUiDisabledBg",
        "disabledText": "$darkUiDisabledText",
        "focusRing": "$darkInfoMain"
      },
      "alerts": {
        "success": {
          "bg": "$darkAlertSuccessBg",
          "color": "$darkAlertSuccessColor",
          "filledBg": "$darkAlertSuccessFilledBg",
          "filledColor": "$white"
        },
        "warning": {
          "bg": "$darkAlertWarningBg",
          "color": "$darkAlertWarningColor",
          "filledBg": "$darkAlertWarningFilledBg",
          "filledColor": "$white"
        },
        "error": {
          "bg": "$darkAlertErrorBg",
          "color": "$darkAlertErrorColor",
          "filledBg": "$darkAlertErrorFilledBg",
          "filledColor": "$white"
        },
        "info": {
          "bg": "$darkAlertInfoBg",
          "color": "$darkAlertInfoColor",
          "filledBg": "$darkAlertInfoFilledBg",
          "filledColor": "$white"
        },
        "default": {
          "bg": "$darkBgPaper",
          "color": "$darkTextSecondary",
          "filledBg": "$darkAlertDefaultFilledBg",
          "filledColor": "$darkTextPrimary"
        }
      }
    }
  }
}