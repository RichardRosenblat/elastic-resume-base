{
  "mode": "light",
  "variables": {
    "white": "#FFFFFF",
    "primaryMain": "#1F5AA6",
    "primaryLight": "#4B84CE",
    "primaryDark": "#163F73",
    "secondaryMain": "#0D9488",
    "secondaryLight": "#3AB9AD",
    "secondaryDark": "#0A6C63"
  },
  "branding": {
    "appName": "Elastic Resume Base",
    "companyName": "Acme Talent",
    "appLogoUrl": "",
    "companyLogoUrl": ""
  },
  "typography": {
    "fontFamily": "\"Source Sans 3\", \"Segoe UI\", \"Helvetica Neue\", sans-serif"
  },
  "icons": {
    "default": "mdi:home"
  },
  "palette": {
    "primary": {
      "main": "$primaryMain",
      "light": "$primaryLight",
      "dark": "$primaryDark",
      "contrastText": "$white"
    },
    "secondary": {
      "main": "$secondaryMain",
      "light": "$secondaryLight",
      "dark": "$secondaryDark",
      "contrastText": "$white"
    },
    "tertiary": {
      "main": "#F59E0B"
    },
    "success": { "main": "#198754" },
    "warning": { "main": "#B7791F" },
    "error": { "main": "#C53030" },
    "info": { "main": "#2563EB" },
    "background": {
      "default": "#F3F7FC",
      "paper": "$white",
      "elevated": "$white",
      "sidebar": "#EAF1FB",
      "topbar": "$white",
      "input": "$white"
    },
    "text": {
      "primary": "#112133",
      "secondary": "#3E5166",
      "muted": "#657990",
      "inverse": "$white"
    },
    "ui": {
      "border": "#CFDAE8",
      "divider": "#D8E2EE",
      "disabledBackground": "#E6ECF4",
      "disabledText": "#8092A6",
      "focusRing": "#3A7BD5"
    },
    "alerts": {
      "success": {
        "bg": "#EDF7ED",
        "color": "#1D5E28",
        "filledBg": "#198754",
        "filledColor": "$white"
      },
      "warning": {
        "bg": "#FFF8E1",
        "color": "#7A5310",
        "filledBg": "#B7791F",
        "filledColor": "$white"
      },
      "error": {
        "bg": "#FDEDED",
        "color": "#8B1A1A",
        "filledBg": "#C53030",
        "filledColor": "$white"
      },
      "info": {
        "bg": "#E8F4FD",
        "color": "#1A4B8C",
        "filledBg": "#2563EB",
        "filledColor": "$white"
      },
      "default": {
        "bg": "#F3F7FC",
        "color": "#3E5166",
        "filledBg": "#3E5166",
        "filledColor": "$white"
      }
    }
  },
  "sidebar": {
    "mainScreen": "/",
    "defaultCollapsed": false,
    "items": [
      { "path": "/", "order": 1 },
      { "path": "/resumes", "order": 2 },
      { "path": "/search", "order": 3 },
      { "path": "/documents", "order": 4 },
      { "path": "/users", "order": 5 },
      { "path": "/system-status", "order": 6 },
      { "path": "/account", "order": 7 }
    ]
  },
  "presets": {
    "dark": {
      "primary": {
        "main": "$primaryLight",
        "light": "#79ABDF",
        "dark": "$primaryMain",
        "contrastText": "$white"
      },
      "secondary": {
        "main": "$secondaryLight",
        "light": "#68CFC5",
        "dark": "$secondaryMain",
        "contrastText": "$white"
      },
      "tertiary": {
        "main": "#F59E0B"
      },
      "success": { "main": "#4ADE80" },
      "warning": { "main": "#FBBF24" },
      "error": { "main": "#F87171" },
      "info": { "main": "#60A5FA" },
      "background": {
        "default": "#0F172A",
        "paper": "#1E293B",
        "elevated": "#263449",
        "sidebar": "#162032",
        "topbar": "#1A2840",
        "input": "#263449"
      },
      "text": {
        "primary": "#F1F5F9",
        "secondary": "#94A3B8",
        "muted": "#64748B",
        "inverse": "#0F172A"
      },
      "ui": {
        "border": "#2D3F56",
        "divider": "#233045",
        "disabledBackground": "#1E2D3D",
        "disabledText": "#506275",
        "focusRing": "#60A5FA"
      },
      "alerts": {
        "success": {
          "bg": "#0D2B17",
          "color": "#86EFAC",
          "filledBg": "#15803D",
          "filledColor": "$white"
        },
        "warning": {
          "bg": "#2B1D0A",
          "color": "#FCD34D",
          "filledBg": "#B45309",
          "filledColor": "$white"
        },
        "error": {
          "bg": "#2B0D0D",
          "color": "#FCA5A5",
          "filledBg": "#DC2626",
          "filledColor": "$white"
        },
        "info": {
          "bg": "#0D1F3C",
          "color": "#93C5FD",
          "filledBg": "#1D4ED8",
          "filledColor": "$white"
        },
        "default": {
          "bg": "#1E293B",
          "color": "#94A3B8",
          "filledBg": "#334155",
          "filledColor": "#F1F5F9"
        }
      }
    }
  }
}
