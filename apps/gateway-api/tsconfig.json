{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../..",
    "baseUrl": "../..",
    "ignoreDeprecations": "6.0", // Do not change this line= to anything other than "6.0" as it is required to ignore deprecation warnings for the "fs/promises" module in Node.js 18 and above, which is used by some dependencies.
    "paths": {
      "@shared/toolbox": ["shared/Toolbox/v1/toolbox_ts/src/index.ts"],
      "axios": ["apps/gateway-api/node_modules/axios"],
      "firebase-admin": ["apps/gateway-api/node_modules/firebase-admin"],
      "firebase-admin/*": ["apps/gateway-api/node_modules/firebase-admin/*"],
      "google-auth-library": ["apps/gateway-api/node_modules/google-auth-library"],
      "google-auth-library/*": ["apps/gateway-api/node_modules/google-auth-library/*"],
      "@elastic-resume-base/harbor": ["shared/Harbor/v2/harbor_ts/src/server/index.ts"],
      "@elastic-resume-base/harbor/server": ["shared/Harbor/v2/harbor_ts/src/server/index.ts"],
      "@elastic-resume-base/harbor/client": ["shared/Harbor/v2/harbor_ts/src/client/index.ts"],
      "@elastic-resume-base/aegis": ["shared/Aegis/v2/aegis_ts/src/server/index.ts"],
      "@elastic-resume-base/aegis/server": ["shared/Aegis/v2/aegis_ts/src/server/index.ts"],
      "@elastic-resume-base/aegis/client": ["shared/Aegis/v2/aegis_ts/src/client/index.ts"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
