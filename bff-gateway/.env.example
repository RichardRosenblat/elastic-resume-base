PORT=3000
NODE_ENV=development
FIREBASE_PROJECT_ID=demo-elastic-resume-base

# Firebase emulator settings (for local development)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Downstream service URLs
DOWNLOADER_SERVICE_URL=http://localhost:8001
SEARCH_BASE_SERVICE_URL=http://localhost:8002
FILE_GENERATOR_SERVICE_URL=http://localhost:8003
DOCUMENT_READER_SERVICE_URL=http://localhost:8004
USER_API_SERVICE_URL=http://localhost:8005

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# GCP project identifier (used for Cloud Logging / Error Reporting)
GCP_PROJECT_ID=demo-elastic-resume-base

# Comma-separated list of allowed email domains for user creation/update.
# Leave empty to allow all domains.
# Example: ALLOWED_EMAIL_DOMAINS=company.com,partner.org
ALLOWED_EMAIL_DOMAINS=
