PORT=3000
NODE_ENV=development
FIREBASE_PROJECT_ID=demo-elastic-resume-base

# Firebase emulator settings (for local development)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Downstream service URLs
DOWNLOADER_SERVICE_URL=http://localhost:8001
SEARCH_BASE_SERVICE_URL=http://localhost:8002
FILE_GENERATOR_SERVICE_URL=http://localhost:8003
DOCUMENT_READER_SERVICE_URL=http://localhost:8004

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000
