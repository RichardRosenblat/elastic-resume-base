{
  "name": "bff-gateway",
  "version": "1.0.0",
  "description": "Backend For Frontend gateway for Elastic Resume Base",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
