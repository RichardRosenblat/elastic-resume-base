# Environment Variables Template
#
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file to version control.
#
# Usage:
#   cp .env.example .env
#

# =============================================================================
# Google Cloud Platform
# =============================================================================

# Your GCP project ID (e.g., elastic-resume-base-dev)
GCP_PROJECT_ID=

# =============================================================================
# Firebase / Firestore
# =============================================================================

# Set these when using the Firebase Local Emulator Suite for local development.
# Leave blank (or unset) in production — the SDK will connect to the live services.
FIRESTORE_EMULATOR_HOST=firebase-emulator:8080
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099

# =============================================================================
# Cloud Pub/Sub
# =============================================================================

# Set when using the Pub/Sub emulator locally.
PUBSUB_EMULATOR_HOST=firebase-emulator:8085

# Pub/Sub topic names
PUBSUB_INGESTOR_TOPIC=resume-ingested
PUBSUB_AI_WORKER_TOPIC=resume-extracted
PUBSUB_SEARCH_INDEX_TOPIC=resume-indexed
PUBSUB_DLQ_TOPIC=dead-letter-queue

# =============================================================================
# BFF Gateway (Node.js)
# =============================================================================

NODE_ENV=development
PORT=3000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

LOG_LEVEL=info

# =============================================================================
# Python Microservices
# =============================================================================

LOG_LEVEL=INFO

# Firestore collection names
FIRESTORE_RESUMES_COLLECTION=resumes
FIRESTORE_USERS_COLLECTION=users

# =============================================================================
# Vertex AI (AI Worker)
# =============================================================================

VERTEX_AI_LOCATION=us-central1
VERTEX_AI_EXTRACTION_MODEL=gemini-1.5-flash
VERTEX_AI_EMBEDDING_MODEL=text-multilingual-embedding-002

# =============================================================================
# Cloud KMS (PII Encryption)
# =============================================================================

KMS_KEY_RING=elastic-resume-keyring
KMS_KEY_NAME=resume-pii-key
KMS_KEY_LOCATION=global

# =============================================================================
# Search Base (FAISS)
# =============================================================================

# Path to store the FAISS index file within the container
FAISS_INDEX_PATH=/app/data/resume.faiss

# =============================================================================
# Translation (File Generator)
# =============================================================================

TRANSLATION_CACHE_COLLECTION=translation-cache

# =============================================================================
# DLQ Notifier
# =============================================================================

# Notification channel (e.g., slack, email)
DLQ_NOTIFICATION_CHANNEL=slack
DLQ_SLACK_WEBHOOK_URL=
