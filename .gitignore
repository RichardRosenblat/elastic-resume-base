# =============================================================================
# Elastic Resume Base – Global .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment and secrets (NEVER commit these)
# -----------------------------------------------------------------------------
# config.yaml is the user's local configuration (contains real values).
# config_example.yaml is the committed template with safe defaults.
# Per-service .env files (e.g. bff-gateway/.env) are auto-generated by
# scripts/setup-env.py from config.yaml — never commit them.
config.yaml
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
service-account*.json
gcloud-credentials*.json
application_default_credentials.json

# -----------------------------------------------------------------------------
# Node.js / npm / Yarn / pnpm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnp.*

# Build output
# NOTE: dist/ is intentionally NOT ignored for packages under shared/ — those
# compiled outputs must be committed so that consuming services can resolve the
# packages via their "exports" field without a build step.  All other dist/
# directories (apps, services) remain ignored by the rule below.
dist/
build/
out/
.next/
.nuxt/
.vite/

# TypeScript cache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
*.egg-info/
.eggs/
dist/
build/
wheels/
*.whl
*.egg
MANIFEST

# Coverage and test artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# pyenv
.python-version

# pip-tools
requirements.txt.bak

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Do not ignore Dockerfiles – they should be committed
# Ignore local Docker volumes and overrides
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (IntelliJ, PyCharm, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# -----------------------------------------------------------------------------
# Google Cloud / Firebase
# -----------------------------------------------------------------------------
.firebaserc
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
pubsub-debug.log
ui-debug.log
.firebase/

# gcloud
.gcloud/

# -----------------------------------------------------------------------------
# Testing and coverage
# -----------------------------------------------------------------------------
coverage/
lcov.info
*.lcov

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp

# -----------------------------------------------------------------------------
# Compiled binaries and FAISS index files
# -----------------------------------------------------------------------------
*.faiss
*.index
*.bin
*.pkl

# -----------------------------------------------------------------------------
# Shared library build outputs
# -----------------------------------------------------------------------------
# The dist/ directories under shared/* must NOT be ignored so that consuming
# apps (bff-gateway, users-api) can resolve these packages via their declared
# "exports" field without requiring a separate build step.
# All other dist/ directories (apps and services) remain ignored by the dist/
# rules above.
!shared/
!shared/*/
!shared/*/dist/
!shared/*/dist/**