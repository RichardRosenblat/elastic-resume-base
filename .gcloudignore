# Files excluded from the `gcloud builds submit` source upload.
# Cloud Build only needs the source code; everything else is a waste of
# bandwidth and build time.

# ── Version control metadata ───────────────────────────────────────────────
.git

# ── Documentation / scripts ────────────────────────────────────────────────
documentation
Scripts
*.md
*.bat
*.sh
apphosting.emulator.yaml
firebase.json
docker-compose.yml
config_example.yaml
config.yaml
start_firebase_emulators.bat
start_firebase_emulators.sh
build_shared.bat
build_shared.sh

# ── Node artifacts (reinstalled by Cloud Build) ────────────────────────────
**/node_modules

# ── Build outputs (rebuilt by Cloud Build) ─────────────────────────────────
**/dist
**/build

# ── Python artifacts ───────────────────────────────────────────────────────
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/*.egg-info

# ── Test & coverage outputs ────────────────────────────────────────────────
**/coverage
**/test-results
**/*.log

# ── Environment / secrets ──────────────────────────────────────────────────
**/.env
**/.env.*

# ── IDE / OS ───────────────────────────────────────────────────────────────
.vscode
.idea
.DS_Store
Thumbs.db
