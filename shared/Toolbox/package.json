{
  "name": "@elastic-resume-base/toolbox",
  "version": "1.0.0",
  "description": "Shared cross-cutting utilities for Elastic Resume Base microservices: structured logging, config loading, and Fastify middleware",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --forceExit",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage"
  },
  "dependencies": {
    "@google-cloud/pino-logging-gcp-config": "^1.3.3",
    "js-yaml": "^4.1.1",
    "pino": "9.1.0",
    "uuid": "9.0.1"
  },
  "peerDependencies": {
    "fastify": "^5.7.2"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.12.7",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "7.8.0",
    "@typescript-eslint/parser": "7.8.0",
    "eslint": "8.57.0",
    "fastify": "^5.7.2",
    "jest": "29.7.0",
    "pino-pretty": "^11.0.0",
    "prettier": "3.2.5",
    "ts-jest": "29.1.4",
    "tsx": "4.19.3",
    "typescript": "5.4.5"
  }
}
