{
  "name": "@elastic-resume-base/toolbox",
  "version": "1.1.0",
  "description": "Shared cross-cutting utility definitions for Elastic Resume Base microservices",
  "type": "module",
  "scripts": {
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --forceExit",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.12.7",
    "@typescript-eslint/eslint-plugin": "7.8.0",
    "@typescript-eslint/parser": "7.8.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "js-yaml": "4.1.0",
    "prettier": "3.2.5",
    "ts-jest": "29.1.4",
    "tsx": "4.19.3",
    "typescript": "5.4.5"
  }
}
