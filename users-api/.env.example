PORT=8005
NODE_ENV=development
FIREBASE_PROJECT_ID=demo-elastic-resume-base

# Firebase emulator settings (for local development)
FIRESTORE_EMULATOR_HOST=localhost:8080

# Google Service Account credentials (Base64-encoded or raw JSON)
# Required for Google Drive access via Bugle
GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional: Google Sheet / Drive File ID used to check admin access.
# If set, the /users/:uid/role endpoint uses Google Drive permissions (Bugle)
# to determine access. If unset, Firestore user records are used instead.
ADMIN_SHEET_FILE_ID=

# Logging
LOG_LEVEL=info

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# GCP project identifier (used for Cloud Logging)
GCP_PROJECT_ID=demo-elastic-resume-base
